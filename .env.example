# No paid API keys required for core pipeline.
# Optionally set the following for full data coverage.

# FRED API (free registration at https://fred.stlouisfed.org)
# FRED_API_KEY=your_fred_api_key

# Reddit API (free at https://www.reddit.com/prefs/apps)
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret

# Optional: MLflow tracking server (default: local)
# MLFLOW_TRACKING_URI=http://localhost:5000

# Optional: Prefect API (default: local)
# PREFECT_API_URL=http://localhost:4200/api
